# ── Database ────────────────────────────────────────────────────────────────
# Matches docker-compose.yml. Override host/port if you run Postgres elsewhere.
DATABASE_URL=postgresql://mica:mica@127.0.0.1:5433/mica

# ── Claude (required for /chat and /classify) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Agent loop model + cheap sub-task model. Sonnet 4.6 is the cost-effective default;
# set AGENT_MODEL=claude-opus-4-8 for maximum quality (higher cost).
AGENT_MODEL=claude-sonnet-4-6
CHEAP_MODEL=claude-haiku-4-5

# ── Embeddings ────────────────────────────────────────────────────────────────
# EMBEDDER=voyage  -> uses Voyage `voyage-law-2` (legal-tuned, 1024-dim). Needs VOYAGE_API_KEY.
# EMBEDDER=local   -> mixedbread-ai/mxbai-embed-large-v1 (1024-dim, ~0.64 GB). No API key, offline.
#   For multilingual (EL/EN) retrieval, swap LOCAL_EMBED_MODEL=intfloat/multilingual-e5-large (also 1024-dim).
EMBEDDER=local
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-law-2
LOCAL_EMBED_MODEL=mixedbread-ai/mxbai-embed-large-v1
EMBED_DIM=1024

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=20
RETURN_K=6

# ── News corpus (v2) ──────────────────────────────────────────────────────────
# fulltext = store full article text for highest answer accuracy (default).
# summary  = store a Haiku transformative summary instead (copyright-safer, small API cost).
NEWS_STORE=fulltext
NEWS_RETURN_K=6
NEWS_PRESS_MINUTES=10
NEWS_REGULATORS_HOURS=6

# ── CORS (Next.js dev server) ─────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
